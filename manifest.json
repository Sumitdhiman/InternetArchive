{
  "manifest_version": 3,
  "name": "Internet Archive - Paywall bypass and archive access",
  "version": "3.0.1",
  "description": "Access archived versions of any webpage instantly. Bypass paywalls, view deleted content, and explore web history with one click.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "contextMenus"
  ],
  "action": {
    "default_title": "Open Page Archive",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/scripts/background.js"
  },
  "commands": {
    "archive_current_page": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open the Popup/Archive."
    }
  },
  "icons": {
    "16": "assets/images/icon16.png",
    "48": "assets/images/icon48.png",
    "128": "assets/images/icon128.png"
  }
}
